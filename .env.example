# Copy this file to .env and fill in your values
# Never commit .env to version control

# SMTP — Gmail example (use an App Password, not your main password)
# Google: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kinevrin@gmail.com
SMTP_PASS=your_app_password_here

# Where to receive enquiries (can be same as SMTP_USER)
NOTIFY_EMAIL=kinevrin@gmail.com

# Server port (default 3000)
PORT=3000
